# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGIN=http://localhost:4200

# GitHub Personal Access Token
# Fine-grained PAT (recommended): requires Metadata read-only for Phase 3-6,
# Administration read/write for Phase 7+ (visibility changes and deletion)
# Classic PAT fallback: repo + delete_repo scopes (grants more access than CodeShelf uses)
GITHUB_TOKEN=

# AI Provider — set AI_PROVIDER to choose which adapter is used
# Options: openai | anthropic | ollama | mock | none
# Use "mock" for testing without an API key. Use "none" to disable AI entirely.
AI_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Only required if AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
