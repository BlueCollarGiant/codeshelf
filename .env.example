# ── Server ────────────────────────────────────────────────────────────────
# NODE_ENV: standard Node environment flag. CodeShelf only runs locally, so
# "development" is the normal value.
NODE_ENV=development

# PORT: the port the local Express backend listens on (127.0.0.1 only).
# If you change it, also update API_BASE in
# frontend/src/app/core/api.constants.ts so the frontend can find the backend.
PORT=3000

# ALLOWED_ORIGIN: the browser origin allowed by CORS. Only needed if you run
# the Angular dev server on a non-default port. Must be a localhost origin —
# non-localhost values are rejected and the default is used instead.
ALLOWED_ORIGIN=http://localhost:4200

# ── GitHub Personal Access Token (required) ───────────────────────────────
# Used only by the local backend. Never reaches the browser or AI providers.
#
# Fine-grained PAT (recommended):
#   - Read repos and scores only:        Repository -> Metadata -> Read-only
#   - Change visibility / delete repos:  Repository -> Administration -> Read/write
# Classic PAT (fallback): repo scope; add delete_repo only if you want deletion.
#   Classic tokens grant more access than CodeShelf uses — prefer fine-grained.
GITHUB_TOKEN=

# ── AI (optional) ──────────────────────────────────────────────────────────
# AI_PROVIDER selects the analysis adapter:
#   none      - AI disabled (default; unset or unrecognised values also disable it)
#   mock      - seeded local test results, no API key needed
#   openai    - requires OPENAI_API_KEY
#   anthropic - requires ANTHROPIC_API_KEY
#   ollama    - local Ollama instance, no cloud key needed
AI_PROVIDER=none

# OPENAI_API_KEY: only required if AI_PROVIDER=openai.
OPENAI_API_KEY=

# ANTHROPIC_API_KEY: only required if AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# OLLAMA_URL / OLLAMA_MODEL: only used if AI_PROVIDER=ollama.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
